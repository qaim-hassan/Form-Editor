# Runtime connection (use Neon *pooler* host on Vercel/serverless)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/formbuilder?schema=public"

# Direct connection for migrations (same as DATABASE_URL for local Postgres)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/formbuilder?schema=public"

PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100