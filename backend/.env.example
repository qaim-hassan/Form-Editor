# Local Postgres, or Neon direct URL for local dev / migrations
# On Vercel use Neon *pooler* URL for DATABASE_URL (see docs/DEPLOY-VERCEL.md)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/formbuilder?schema=public"

PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100